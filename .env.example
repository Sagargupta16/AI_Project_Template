# Copy to .env and fill in. Never commit .env.
# Pydantic Settings reads these at startup. Nested delimiter is `__`.

# --- App ---
ENV=dev
LOG_LEVEL=INFO

# --- ML (prefix ML_) ---
ML_RANDOM_SEED=42
ML_TEST_SIZE=0.2

# --- LLM (prefix LLM_) ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
# LLM_API_KEY=sk-ant-...

# Raw provider keys (read directly by SDKs)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- RAG (prefix RAG_) ---
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_VECTOR_STORE=chroma

# --- Observability (prefix OBS_) ---
OBS_TRACING_ENABLED=false
OBS_TRACING_BACKEND=phoenix
OBS_COST_TRACKING=true
